# Deployment Configuration
# This file contains deployment settings for the production VM
# Copy this to deploy.config.local and customize (deploy.config.local is gitignored)

# SSH Connection Details
# Prefer deploy.config.local (gitignored): set SSH_HOST, SSH_USER, SSH_KEY to your private key for key-based login.
SSH_HOST=20.224.64.96
SSH_USER=racesight
SSH_KEY=C:\Users\guyt2\OneDrive\Projects\AzureVM\RaceSight\racesight-azure-vm.pub.pem
# SSH_USE_MULTIPLEX=force
# Optional. Win32-OpenSSH defaults to NO multiplex (scp fails with ControlMaster). Use an SSH key to avoid many password prompts.

# VM Deployment Paths
VM_BASE_PATH=/home/racesight/racesight
VM_FRONTEND_PATH=/home/racesight/racesight/frontend
VM_SERVERS_PATH=/home/racesight/racesight/servers
VM_DATA_PATH=/home/racesight/racesight/data
VM_MEDIA_PATH=/home/racesight/racesight/media
VM_SCRIPTS_PATH=/opt/racesight/scripts

# Docker Configuration
DOCKER_NETWORK_NAME=hunico-network
DOCKER_COMPOSE_FILE=docker-compose.yml

# Deployment Options
# DEPLOY_VM_SERVERS.bat backs up the whole servers/docker/nginx/ssl/ tree to VM_BASE_PATH/.deploy-ssl-preserve
# before wiping VM_SERVERS_PATH, merges it back after extract, then runs ensure-nginx-tls-on-vm.sh if
# fullchain.pem + privkey.pem are still missing (PEMs are not in git).
# Optional extra IP in generated self-signed SAN if your VM address is not 10.100.30.110 (VPN/LAN).
# DEPLOY_NGINX_TLS_SAN_IP=10.100.30.110
DEPLOY_RESTART_SERVICES=true
DEPLOY_DRY_RUN=false
# Step 5a: sudo chown on VM paths. Step 6: chmod 644 on docker-compose.yml on VM. Set false to skip both if paths/files are already owned by SSH_USER and you want no sudo/chmod prompts.
DEPLOY_SUDO_CHOWN=true

# Environment
DEPLOY_ENV=production

