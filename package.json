{
  "name": "teamshare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "libs/*"
  ],
  "scripts": {
    "predev": "node scripts/build-syncstore.js && node scripts/copy-sqlite-workers.js",
    "dev": "vite",
    "prebuild": "npm run build:hunidb && node scripts/copy-sqlite-workers.js",
    "build": "vite build",
    "build:hunidb": "npm run build --workspace @hunico/hunidb",
    "lint": "eslint frontend --ext js,jsx,ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint frontend --ext js,jsx,ts,tsx --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run frontend/__tests__/unit",
    "test:integration": "vitest run frontend/__tests__/integration",
    "test:solidjs": "vitest run frontend/__tests__/integration/solidjs",
    "test:loops": "vitest run frontend/__tests__/integration/solidjs/infiniteLoopDetection.test.ts",
    "test:e2e": "vitest run frontend/__tests__/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:streaming": "vitest run server_stream/__tests__ frontend/__tests__/unit/store/streamingStore.test.ts",
    "test:streaming:integration": "node server_stream/__tests__/integration/test-processor-redis.js && node server_stream/__tests__/integration/test-influx-stream-to-redis.js",
    "test:streaming:integration:all": "node server_stream/__tests__/run-all-integration-tests.js",
    "test:streaming:integration:full": "node server_stream/__tests__/integration/test-full-data-flow.js",
    "test:streaming:integration:queries": "node server_stream/__tests__/integration/test-query-format-scenarios.js",
    "test:streaming:integration:channels": "node server_stream/__tests__/integration/test-channel-normalization-pipeline.js",
    "test:server_file": "cd server_file && npm test",
    "test:streaming:processor": "node server_stream/__tests__/test-processor.js",
    "server:admin": "nodemon --config nodemon.admin.json",
    "server:app": "nodemon --config nodemon.app.json",
    "server:file": "nodemon --config nodemon.file.json",
    "server:media": "nodemon --config nodemon.media.json",
    "servers:all": "concurrently \"npm run server:admin\" \"npm run server:app\" \"npm run server:file\" \"npm run server:media\"",
    "postinstall": "node scripts/build-syncstore.js"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "minimatch": "^10.2.1"
  },
  "dependencies": {
    "@influxdata/influxdb-client": "^1.35.0",
    "@solidjs/router": "^0.10.0",
    "@solidjs/sync": "github:thechadturner/syncstore#fa25a919e9aaadf14a6c2d2704ef5a977d1623a3",
    "apache-arrow": "^21.0.0",
    "autoprefixer": "^10.4.16",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "d3": "^7.8.5",
    "d3-drag": "^3.0.0",
    "d3-regression": "^1.3.10",
    "d3-selection": "^3.0.0",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "mapbox-gl": "^2.15.0",
    "pg": "^8.16.3",
    "postcss": "^8.4.32",
    "quill": "^2.0.3",
    "request-ip": "^3.3.0",
    "robust-point-in-polygon": "^1.0.3",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.8.7",
    "tailwindcss": "^3.3.6",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/mapbox-gl": "^2.7.18",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^8.2.2",
    "eslint": "^8.53.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-solid": "^0.12.0",
    "jsdom": "^23.0.1",
    "nodemon": "^3.1.10",
    "playwright": "^1.55.1",
    "rollup-plugin-visualizer": "^5.9.2",
    "supertest": "^7.1.4",
    "terser": "^5.44.1",
    "typescript": "^5.2.2",
    "vite": "^7.1.9",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^3.2.4"
  }
}
